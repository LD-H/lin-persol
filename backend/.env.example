# ── 数据库连接（本地 MySQL）────────────────────────────
# 格式：mysql://用户名:密码@主机:端口/数据库名
# 本地开发默认配置，修改 your_password 为你的 MySQL root 密码
DATABASE_URL="mysql://root:your_password@localhost:3306/personal_site"

# ── 服务端口 ─────────────────────────────────────────
PORT=3001

# ── 阿里云 OSS 配置 ───────────────────────────────────
# 在 https://oss.console.aliyun.com/ 获取
OSS_REGION="oss-cn-hangzhou"
OSS_ACCESS_KEY_ID="your_access_key_id"
OSS_ACCESS_KEY_SECRET="your_access_key_secret"
OSS_BUCKET="your_bucket_name"
OSS_BASE_URL="https://your_bucket_name.oss-cn-hangzhou.aliyuncs.com"

# ── 前端域名（CORS 配置）──────────────────────────────
FRONTEND_URL="http://localhost:5173"